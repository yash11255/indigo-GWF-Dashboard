# ── Server environment variables ───────────────────────────────────────────────
# Copy this file to .env for local development
# Set these as Environment Variables in Vercel dashboard for production

# Server port (local dev only — Vercel ignores this)
PORT=4001

# JWT secret — use a long random string in production
JWT_SECRET=indigo-wings-secret-key-2026

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=indigo@2026

# Client login credentials
CLIENT_USERNAME=client
CLIENT_PASSWORD=client@2026

# Frontend URL for CORS (set to your Vercel frontend URL in production)
CLIENT_URL=http://localhost:5173

# Set to "production" in Vercel
NODE_ENV=development
