{
  "version": 2,
  "buildCommand": "npm install && node scripts/prebuild.js && mkdir -p public",
  "outputDirectory": "public",
  "installCommand": "echo 'deps handled in buildCommand'",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "src/**,data/**,node_modules/**,package.json,27062026_IGWF_Applicants_List.xlsx"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1"
  }
}
