{
  "version": 2,
  "installCommand": "npm install && node scripts/prebuild.js",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "src/**,data/**,node_modules/**,package.json,*.xlsx"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
