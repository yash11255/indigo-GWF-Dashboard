{
  "version": 2,
  "installCommand": "npm install && node scripts/prebuild.js",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30,
        "memory": 1024,
        "includeFiles": ["src/**", "data/**", "*.xlsx"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
