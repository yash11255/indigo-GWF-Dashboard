# ── Backend environment variables ──────────────────────────────────────────────
# Set these in Vercel → Project → Settings → Environment Variables

# JWT secret — change this to a long random string in production
JWT_SECRET=indigo-wings-secret-key-2026

# Admin credentials (override defaults)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=indigo@2026

# Client credentials (override defaults)
CLIENT_USERNAME=client
CLIENT_PASSWORD=client@2026

# Frontend URL for CORS — set to your Vercel frontend URL
CLIENT_URL=https://your-frontend-project.vercel.app

# Node env
NODE_ENV=production
VERCEL=1
