{
  "version": 2,
  "buildCommand": "node scripts/prebuild.js && cd server && npm install",
  "installCommand": "cd server && npm install",
  "functions": {
    "api/server.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "server/src/**,server/data/**,server/node_modules/**,server/package.json"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1"
  }
}
